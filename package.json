{
    "name": "geogebra-standalone",
    "version": "1.0.0",
    "main": "dist/main/main.cjs",
    "author": {
        "name": "Thomas Michael Weissel",
        "email": "valueerror@gmail.com",
        "url": "https://next-exam.at"
    },
    "homepage": "https://next-exam.at",
    "license": "GPL-3.0",
    "description": "A standalone version of geogebra for linux",
    "type": "module",
    "scripts": {
        "dev": "node scripts/watch.mjs",
        "build": "node scripts/build.mjs && electron-builder -l",
        "build:mac": "node scripts/build.mjs && electron-builder -m",
        "build:win": "node scripts/build.mjs && electron-builder -w"
    },
    "build": {
        "productName": "GeoGebra-Standalone",
        "appId": "com.geogebra-osos.app",
        "asar": {
            "smartUnpack": true
        },
        "afterSign": "scripts/notarize.cjs",
        "asarUnpack": [
            "public"
        ],
        "directories": {
            "output": "../release/${version}"
        },
        "compression": "normal",
        "files": [
            "dist",
            "public"
        ],
        "linux": {
            "target": "AppImage",
            "category": "Utility",
            "icon": "public/icons/256x256.png",
            "artifactName": "${productName}_${version}.${ext}"
        },
        "mac": {
            "icon": "public/icons/icon.png",
            "artifactName": "${productName}_${version}_${arch}.${ext}",
            "hardenedRuntime": true,
            "gatekeeperAssess": false,
            "entitlements": "entitlements.mac.plist",
            "entitlementsInherit": "entitlements.mac.plist",
            "category": "public.app-category.utilities",
            "target": {
                "target": "dmg",
                "arch": [
                    "universal"
                ]
            }
        },
        "dmg": {
            "sign": "true"
        },
        "portable": {
            "useZip": true,
            "unpackDirName": true,
            "splashImage": "public/splash.bmp"
        },
        "win": {
            "icon": "public/icons/icon.ico",
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "artifactName": "${productName}_${version}.${ext}",
            "certificateSubjectName": "OSOS Austria",
            "signingHashAlgorithms": [
                "sha256"
            ]
        }
    },
    "engines": {
        "node": "^12.20.0 || ^14.13.1 || >=16.0.0"
    },
    "devDependencies": {
        "@intlify/vite-plugin-vue-i18n": "^3.3.1",
        "@types/screenshot-desktop": "^1.12.0",
        "@vitejs/plugin-vue": "^2.3.4",
        "electron": "^24.1.2",
        "electron-builder": "^24.2.1",
        "electron-notarize": "^1.2.2",
        "nodemon": "^2.0.15",
        "typescript": "^4.5.5",
        "vite": "^2.7.13",
        "vite-plugin-resolve": "^1.6.1",
        "vue": "^3.2.31"
    },
    "env": {
        "//": "Used in build scripts",
        "PORT": 3001
    },
    "keywords": [
        "vite",
        "electron",
        "vue3",
        "rollup"
    ],
    "dependencies": {
        "archiver": "^5.3.0",
        "axios": "^0.26.0",
        "bootstrap": "^5.3.2",
        "cors": "^2.8.5",
        "electron-log": "^5.0.1",
        "esbuild": "^0.19.11",
        "express": "^4.17.3",
        "express-fileupload": "^1.3.1",
        "fs": "^0.0.1-security",
        "html2pdf-jspdf2": "^0.1.2",
        "ip": "^1.1.5",
        "lowlight": "^2.5.0",
        "moment-timezone": "^0.5.45",
        "node-addon-api": "^7.0.0",
        "node-forge": "^1.3.1",
        "node-gyp": "^10.0.1",
        "node-notifier": "^10.0.1",
        "node-prevent-sleep": "^0.0.4",
        "play-sound": "^1.1.5",
        "sass": "^1.49.9",
        "validator": "^13.7.0",
        "vue-i18n": "^9.1.9",
        "vue-router": "^4.0.13",
        "vue-sweetalert2": "^5.0.2"
    }
}
